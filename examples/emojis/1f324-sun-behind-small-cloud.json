          0.2,
          0.72,
          0.18,
          1
        ]
      },
      {
        "target": "cloud",
        "keyframes": {
          "x": [
            0,
            -1.5,
            2.8,
            1,
            0
          ],
          "y": [
            0,
            0.8,
            -0.5,
            0
          ],
          "scaleX": [
