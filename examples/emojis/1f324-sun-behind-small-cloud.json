            0,
            1,
            -1.8,
            -3,
            -1,
            0
          ],
          "scale": [
            1,
            0.96,
            1.08,
            1.13,
            1.04,
            1
          ],
          "opacity": [
            1,
            0.88,
            1,
            0.94,
            1
          ]
        },
        "duration": 0.82,
